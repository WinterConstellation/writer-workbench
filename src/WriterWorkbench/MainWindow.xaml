<Window x:Class="WriterWorkbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="원고 작업대"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        FontFamily="Malgun Gothic"
        Background="White"
        KeyDown="Window_KeyDown">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveCommand_Executed"/>
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Command="ApplicationCommands.Save" Key="S" Modifiers="Control"/>
    </Window.InputBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Height="78"
                Background="#F5F6F8"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="39"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="새 프로젝트"
                                Tag="project.new"
                                MinWidth="106"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="프로젝트 열기"
                                Tag="project.open"
                                MinWidth="112"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="새 장면"
                                Tag="document.createScene"
                                MinWidth="96"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="저장"
                                Tag="project.save"
                                MinWidth="88"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button x:Name="PreviewModeButton"
                                Content="미리보기"
                                Tag="view.preview.toggle"
                                ToolTip="미리보기로 전환합니다. 기본 단축키: Ctrl+Alt+P."
                                MinWidth="88"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="메인"
                                Tag="view.main.open"
                                ToolTip="프로젝트 메인 화면을 엽니다."
                                MinWidth="82"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button x:Name="FocusButton"
                                Content="집중 40:00"
                                Tag="writing.focus.toggle"
                                MinWidth="104"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button x:Name="AutosaveButton"
                                Content="자동저장 켬"
                                Tag="autosave.toggle"
                                ToolTip="자동저장을 켜거나 끕니다. 단축키: Ctrl+Alt+S."
                                MinWidth="108"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="스트레스 15k"
                                Tag="document.createStressLarge"
                                ToolTip="15,000문단 스트레스 테스트 문서를 만듭니다."
                                MinWidth="96"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="창 분리"
                                Tag="document.detachCurrent"
                                ToolTip="현재 문서를 별도 창으로 엽니다."
                                MinWidth="84"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="스냅샷"
                                Tag="snapshot.createCurrent"
                                ToolTip="현재 장면의 수동 스냅샷을 만듭니다."
                                MinWidth="84"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="현재 TXT"
                                Tag="export.currentScene"
                                ToolTip="현재 장면을 exports 폴더에 TXT로 내보냅니다."
                                MinWidth="86"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                        <Button Content="전체 TXT"
                                Tag="export.fullManuscript"
                                ToolTip="제외 상태가 아닌 장면을 바인더 순서대로 TXT로 내보냅니다."
                                MinWidth="86"
                                Height="30"
                                Margin="8,0,0,0"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <TextBox x:Name="SearchBox"
                                 Width="220"
                                 Height="28"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"/>
                        <Button Content="검색"
                                Tag="search.run"
                                MinWidth="82"
                                Height="30"
                                Padding="10,0"
                                Click="CommandButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="ProjectPathText"
                               VerticalAlignment="Center"
                               Margin="18,0,12,0"
                               Foreground="#4B5563"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Background="#ECEFF3">
                    <Button Content="프리셋 1"
                            Tag="workspace.preset.1"
                            ToolTip="프리셋 1을 적용합니다. Shift를 누른 채 클릭하면 현재 창 위치로 덮어씁니다."
                            MinWidth="88"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CommandButton_Click"/>
                    <Button Content="프리셋 2"
                            Tag="workspace.preset.2"
                            ToolTip="프리셋 2를 적용합니다. Shift를 누른 채 클릭하면 현재 창 위치로 덮어씁니다."
                            MinWidth="88"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CommandButton_Click"/>
                    <Button Content="프리셋 3"
                            Tag="workspace.preset.3"
                            ToolTip="프리셋 3을 적용합니다. Shift를 누른 채 클릭하면 현재 창 위치로 덮어씁니다."
                            MinWidth="88"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CommandButton_Click"/>
                    <Button x:Name="StartupPresetButton"
                            Content="시작 적용 끔"
                            Tag="workspace.startupPreset.cycle"
                            ToolTip="실행 시 자동 적용할 프리셋을 순서대로 바꿉니다."
                            MinWidth="108"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CommandButton_Click"/>
                    <Button Content="단축키"
                            Tag="shortcuts.openSettings"
                            ToolTip="단축키 설정을 엽니다. 기본 단축키: Ctrl+Alt+K."
                            MinWidth="96"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CommandButton_Click"/>
                    <Button Content="도움말"
                            Tag="help.open"
                            ToolTip="작업대 항목별 역할을 엽니다. 기본 단축키는 F1."
                            MinWidth="86"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="CommandButton_Click"/>
                    <ComboBox x:Name="GraphicPresetBox"
                              Width="168"
                              Height="28"
                              Margin="8,0,0,0"
                              DisplayMemberPath="Name"
                              SelectionChanged="GraphicPresetBox_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Height="28"
                   Padding="12,5,12,4"
                   Background="#111827"
                   Foreground="White"
                   FontSize="12"
                   Text="준비됨"/>

        <Border x:Name="OperationProgressPanel"
                DockPanel.Dock="Bottom"
                Height="58"
                Padding="12,7"
                Background="#EAF2FF"
                BorderBrush="#B8CCE8"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="18"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="OperationProgressText"
                           Grid.Row="0"
                           Grid.Column="0"
                           FontSize="12"
                           Foreground="#1F2937"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="OperationEtaText"
                           Grid.Row="0"
                           Grid.Column="1"
                           FontSize="12"
                           Foreground="#1F2937"
                           HorizontalAlignment="Right"/>
                <ProgressBar x:Name="OperationProgressBar"
                             Grid.Row="1"
                             Grid.Column="0"
                             Height="12"
                             Minimum="0"
                             Maximum="100"/>
                <Canvas x:Name="OperationGraphCanvas"
                        Grid.Row="1"
                        Grid.Column="1"
                        Height="34"
                        Margin="18,-12,0,0"
                        Background="#F8FBFF">
                    <Polyline x:Name="OperationRemainingGraph"
                              Stroke="#2563EB"
                              StrokeThickness="2"/>
                </Canvas>
            </Grid>
        </Border>

        <TextBlock x:Name="MetricsText"
                   DockPanel.Dock="Bottom"
                   Height="28"
                   Padding="12,5,12,4"
                   Background="#F3F4F6"
                   Foreground="#374151"
                   FontSize="12"
                   Text="문서 없음"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BinderColumn" Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#F3F4F6"
                    BorderBrush="#D1D5DB"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="바인더"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Padding="12,8"
                               Background="#F9FAFB"/>
                    <WrapPanel DockPanel.Dock="Top"
                               Margin="8,0,8,8"
                               Background="#F9FAFB">
                        <Button Content="이름"
                                Tag="document.renameScene"
                                MinWidth="54"
                                Height="26"
                                Margin="0,0,6,0"
                                Padding="8,0"
                                Click="CommandButton_Click"/>
                        <Button Content="복제"
                                Tag="document.duplicateScene"
                                MinWidth="54"
                                Height="26"
                                Margin="0,0,6,0"
                                Padding="8,0"
                                Click="CommandButton_Click"/>
                        <Button Content="삭제"
                                Tag="document.deleteScene"
                                MinWidth="54"
                                Height="26"
                                Margin="0,0,6,0"
                                Padding="8,0"
                                Click="CommandButton_Click"/>
                        <Button Content="위"
                                Tag="document.moveSceneUp"
                                MinWidth="44"
                                Height="26"
                                Margin="0,0,6,0"
                                Padding="8,0"
                                Click="CommandButton_Click"/>
                        <Button Content="아래"
                                Tag="document.moveSceneDown"
                                MinWidth="54"
                                Height="26"
                                Padding="8,0"
                                Click="CommandButton_Click"/>
                    </WrapPanel>
                    <ListBox x:Name="BinderList"
                             BorderThickness="0"
                             FontSize="14"
                             DisplayMemberPath="Display"
                             SelectionChanged="BinderList_SelectionChanged"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White">
                <Grid>
                    <DockPanel x:Name="EditorSurface">
                        <TextBox x:Name="TitleBox"
                                 DockPanel.Dock="Top"
                                 BorderThickness="0,0,0,1"
                                 BorderBrush="#E5E7EB"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 Padding="14,10"
                                 TextChanged="TitleBox_TextChanged"/>
                        <TextBox x:Name="EditorBox"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 UndoLimit="0"
                                 TextWrapping="NoWrap"
                                 SpellCheck.IsEnabled="False"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 FontSize="18"
                                 Padding="28"
                                 TextChanged="EditorBox_TextChanged"/>
                    </DockPanel>

                    <DockPanel x:Name="PreviewSurface"
                               Visibility="Collapsed">
                        <Border DockPanel.Dock="Top"
                                Height="44"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="편집"
                                        Tag="view.preview.toggle"
                                        MinWidth="86"
                                        Height="30"
                                        Margin="0,0,12,0"
                                        Padding="10,0"
                                        Click="CommandButton_Click"/>
                                <TextBlock Text="미리보기"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="14,0"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="PreviewText"
                                       TextWrapping="Wrap"
                                       FontSize="16"
                                       LineHeight="28"
                                       Padding="28"
                                       Foreground="#1F2937"/>
                        </ScrollViewer>
                    </DockPanel>

                    <DockPanel x:Name="MainSurface"
                               Visibility="Collapsed"
                               Background="White">
                        <Border DockPanel.Dock="Top"
                                Height="48"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="작업으로"
                                        MinWidth="92"
                                        Height="30"
                                        Margin="0,0,12,0"
                                        Padding="10,0"
                                        Click="ReturnToEditorButton_Click"/>
                                <TextBlock Text="메인"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="14,0"/>
                            </DockPanel>
                        </Border>

                        <Grid Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,0,0,18">
                                <TextBlock x:Name="MainProjectTitleText"
                                           FontSize="22"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="MainProjectPathText"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#4B5563"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <UniformGrid x:Name="MainCommandGrid"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         Columns="2"
                                         Rows="7"
                                         Margin="0,0,24,0">
                                <Button Content="새 장면"
                                        Tag="document.createScene"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="저장"
                                        Tag="project.save"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="집중 40:00"
                                        Tag="writing.focus.toggle"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="미리보기"
                                        Tag="view.preview.toggle"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="창 분리"
                                        Tag="document.detachCurrent"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="단축키"
                                        Tag="shortcuts.openSettings"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="프로젝트 열기"
                                        Tag="project.open"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="스트레스 15k"
                                        Tag="document.createStressLarge"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="도움말"
                                        Tag="help.open"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="현재 TXT"
                                        Tag="export.currentScene"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="전체 TXT"
                                        Tag="export.fullManuscript"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="스냅샷"
                                        Tag="snapshot.createCurrent"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>
                                <Button Content="관계도"
                                        Tag="story.relationshipMap.open"
                                        Margin="0,0,10,10"
                                        Click="CommandButton_Click"/>                            </UniformGrid>

                            <DockPanel Grid.Row="1"
                                       Grid.Column="1">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="최근 문서"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <Border x:Name="StoryStructurePanel"
                                        DockPanel.Dock="Bottom"
                                        Height="380"
                                        Margin="0,12,0,0"
                                        Padding="10"
                                        Background="#F9FAFB"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="74"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="82"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="72"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="스토리 구조 / 관계"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="이름"
                                                   Margin="0,0,8,6"
                                                   VerticalAlignment="Center"/>
                                        <TextBox x:Name="StoryNodeNameBox"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Height="26"
                                                 VerticalContentAlignment="Center"
                                                 Margin="0,0,0,6"/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="요약"
                                                   Margin="0,0,8,6"
                                                   VerticalAlignment="Top"/>
                                        <TextBox x:Name="StoryNodeSummaryBox"
                                                 Grid.Row="2"
                                                 Grid.Column="1"
                                                 Height="66"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Margin="0,0,0,6"/>

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="유형"
                                                   Margin="0,0,8,6"
                                                   VerticalAlignment="Center"/>
                                        <DockPanel Grid.Row="3"
                                                   Grid.Column="1"
                                                   Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right"
                                                    Content="추가"
                                                    Tag="story.structure.addNode"
                                                    MinWidth="56"
                                                    Height="26"
                                                    Margin="6,0,0,0"
                                                    Padding="8,0"
                                                    Click="CommandButton_Click"/>
                                            <ComboBox x:Name="StoryNodeKindBox"
                                                      Height="26"
                                                      IsEditable="True"/>
                                        </DockPanel>

                                        <ListBox x:Name="StoryNodeList"
                                                 Grid.Row="4"
                                                 Grid.ColumnSpan="2"
                                                 BorderBrush="#D1D5DB"
                                                 DisplayMemberPath="Display"
                                                 SelectionChanged="StoryNodeList_SelectionChanged"
                                                 Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="5"
                                                   Grid.ColumnSpan="2"
                                                   Text="관계"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>

                                        <Grid Grid.Row="6"
                                              Grid.ColumnSpan="2"
                                              Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="StoryRelationshipSourceBox"
                                                      Grid.Column="0"
                                                      Height="26"
                                                      IsEditable="True"
                                                      DisplayMemberPath="Display"
                                                      Margin="0,0,4,0"/>
                                            <ComboBox x:Name="StoryRelationshipTargetBox"
                                                      Grid.Column="1"
                                                      Height="26"
                                                      IsEditable="True"
                                                      DisplayMemberPath="Display"
                                                      Margin="4,0,0,0"/>
                                        </Grid>

                                        <TextBox x:Name="StoryRelationshipSummaryBox"
                                                 Grid.Row="7"
                                                 Grid.ColumnSpan="2"
                                                 Height="64"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Margin="0,0,0,6"/>

                                        <DockPanel Grid.Row="8"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right"
                                                    Content="관계 추가"
                                                    Tag="story.relationship.add"
                                                    MinWidth="78"
                                                    Height="26"
                                                    Margin="6,0,0,0"
                                                    Padding="8,0"
                                                    Click="CommandButton_Click"/>
                                            <ComboBox x:Name="StoryRelationshipKindBox"
                                                      Height="26"
                                                      IsEditable="True"/>
                                        </DockPanel>

                                        <ListBox x:Name="StoryRelationshipList"
                                                 Grid.Row="9"
                                                 Grid.ColumnSpan="2"
                                                 BorderBrush="#D1D5DB"
                                                 DisplayMemberPath="Display"/>
                                    </Grid>
                                </Border>
                                <ListBox x:Name="MainRecentList"
                                         DisplayMemberPath="Display"
                                         SelectionChanged="MainRecentList_SelectionChanged"/>
                            </DockPanel>
                        </Grid>
                    </DockPanel>

                    <DockPanel x:Name="RelationshipMapSurface"
                               Visibility="Collapsed"
                               Background="White">
                        <Border DockPanel.Dock="Top"
                                Height="44"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="작업대로"
                                        MinWidth="92"
                                        Height="30"
                                        Margin="0,0,12,0"
                                        Padding="10,0"
                                        Click="ReturnToEditorButton_Click"/>
                                <TextBlock Text="관계도"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="14,0"/>
                            </DockPanel>
                        </Border>

                        <Grid Margin="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="280"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="캐릭터"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <ListBox x:Name="RelationshipEntityList"
                                         DockPanel.Dock="Top"
                                         Height="210"
                                         DisplayMemberPath="Display"
                                         SelectionChanged="RelationshipEntityList_SelectionChanged"/>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="관계"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,6"/>
                                <ListBox x:Name="RelationshipList"
                                         DisplayMemberPath="Display"
                                         SelectionChanged="RelationshipList_SelectionChanged"/>
                            </DockPanel>

                            <Border Grid.Column="1"
                                    Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1">
                                <Canvas x:Name="RelationshipMapCanvas"
                                        ClipToBounds="True"
                                        Background="#F8FAFC"/>
                            </Border>

                            <ScrollViewer Grid.Column="2"
                                          Margin="12,0,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="캐릭터 편집"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="이름"/>
                                    <TextBox x:Name="RelationshipEntityNameBox"
                                             Height="28"
                                             Margin="0,2,0,8"/>
                                    <TextBlock Text="유형"/>
                                    <ComboBox x:Name="RelationshipEntityTypeBox"
                                              Height="28"
                                              IsEditable="True"
                                              Margin="0,2,0,8"/>
                                    <TextBlock Text="역할"/>
                                    <TextBox x:Name="RelationshipEntityRoleBox"
                                             Height="28"
                                             Margin="0,2,0,8"/>
                                    <TextBlock Text="요약"/>
                                    <TextBox x:Name="RelationshipEntitySummaryBox"
                                             Height="74"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Margin="0,2,0,8"/>
                                    <TextBlock Text="색상"/>
                                    <TextBox x:Name="RelationshipEntityColorBox"
                                             Height="28"
                                             Text="#2563EB"
                                             Margin="0,2,0,8"/>
                                    <TextBlock Text="태그"/>
                                    <TextBox x:Name="RelationshipEntityTagsBox"
                                             Height="28"
                                             Margin="0,2,0,8"/>
                                    <UniformGrid Columns="3" Margin="0,2,0,14">
                                        <Button Content="추가"
                                                Tag="story.structure.addNode"
                                                Margin="0,0,4,0"
                                                Click="CommandButton_Click"/>
                                        <Button Content="수정"
                                                Tag="story.structure.updateNode"
                                                Margin="2,0,2,0"
                                                Click="CommandButton_Click"/>
                                        <Button Content="삭제"
                                                Tag="story.structure.deleteNode"
                                                Margin="4,0,0,0"
                                                Click="CommandButton_Click"/>
                                    </UniformGrid>

                                    <TextBlock Text="관계 편집"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,8"/>
                                    <TextBlock Text="시작"/>
                                    <ComboBox x:Name="RelationshipSourceBox"
                                              Height="28"
                                              IsEditable="True"
                                              DisplayMemberPath="Display"
                                              Margin="0,2,0,8"/>
                                    <TextBlock Text="도착"/>
                                    <ComboBox x:Name="RelationshipTargetBox"
                                              Height="28"
                                              IsEditable="True"
                                              DisplayMemberPath="Display"
                                              Margin="0,2,0,8"/>
                                    <TextBlock Text="라벨"/>
                                    <TextBox x:Name="RelationshipLabelBox"
                                             Height="28"
                                             Margin="0,2,0,8"/>
                                    <TextBlock Text="메모"/>
                                    <TextBox x:Name="RelationshipNotesBox"
                                             Height="74"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Margin="0,2,0,8"/>
                                    <CheckBox x:Name="RelationshipDirectionalBox"
                                              Content="방향 관계"
                                              Margin="0,0,0,8"/>
                                    <UniformGrid Columns="3">
                                        <Button Content="추가"
                                                Tag="story.relationship.add"
                                                Margin="0,0,4,0"
                                                Click="CommandButton_Click"/>
                                        <Button Content="수정"
                                                Tag="story.relationship.update"
                                                Margin="2,0,2,0"
                                                Click="CommandButton_Click"/>
                                        <Button Content="삭제"
                                                Tag="story.relationship.delete"
                                                Margin="4,0,0,0"
                                                Click="CommandButton_Click"/>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FAFAFA"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="검색 결과"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Padding="12,8"
                               Background="#F9FAFB"/>
                    <Border x:Name="InspectorPanel"
                            DockPanel.Dock="Bottom"
                            Height="540"
                            Padding="12"
                            Background="#F9FAFB"
                            BorderBrush="#D1D5DB"
                            BorderThickness="0,1,0,0">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top"
                                       Margin="0,0,0,8">
                                <Button x:Name="InspectorSaveButton"
                                        DockPanel.Dock="Right"
                                        Content="저장"
                                        MinWidth="64"
                                        Height="28"
                                        Padding="8,0"
                                        Click="InspectorSaveButton_Click"/>
                                <TextBlock Text="장면 정보"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="76"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="82"/>
                                      <RowDefinition Height="Auto"/>
                                      <RowDefinition Height="130"/>
                                 </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="시놉시스"
                                           Margin="0,0,8,6"
                                           VerticalAlignment="Top"/>
                                <TextBox x:Name="InspectorSynopsisBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Grid.RowSpan="2"
                                         Height="72"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="상태"
                                           Margin="0,0,8,8"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="InspectorStatusBox"
                                          Grid.Row="2"
                                          Grid.Column="1"
                                          Height="28"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Status"
                                          Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="태그"
                                           Margin="0,0,8,8"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="InspectorTagsBox"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Height="28"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Text="목표 글자"
                                           Margin="0,0,8,8"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="InspectorTargetCountBox"
                                         Grid.Row="4"
                                         Grid.Column="1"
                                         Height="28"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Text="현재 글자"
                                           Margin="0,0,8,8"/>
                                <TextBlock x:Name="InspectorCurrentCountText"
                                           Grid.Row="5"
                                           Grid.Column="1"
                                           Text="0"
                                           Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Text="공백 제외"
                                           Margin="0,0,8,8"/>
                                <TextBlock x:Name="InspectorContentLengthText"
                                           Grid.Row="6"
                                           Grid.Column="1"
                                           Text="0"
                                           Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Text="공백 포함"
                                           Margin="0,0,8,8"/>
                                <TextBlock x:Name="InspectorContentLengthWithSpacesText"
                                           Grid.Row="7"
                                           Grid.Column="1"
                                           Text="0"
                                           Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Text="장면 유형"
                                           Margin="0,0,8,8"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="InspectorSceneTypeBox"
                                         Grid.Row="8"
                                         Grid.Column="1"
                                         Height="28"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Text="수동 줄바꿈"
                                           Margin="0,0,8,8"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="InspectorManualLineBreakBox"
                                          Grid.Row="9"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Text="수정 시각"
                                           Margin="0,0,8,0"/>
                                 <TextBlock x:Name="InspectorUpdatedAtText"
                                            Grid.Row="10"
                                            Grid.Column="1"
                                            Text="-"
                                            TextTrimming="CharacterEllipsis"/>
                                 <DockPanel Grid.Row="11"
                                            Grid.ColumnSpan="2"
                                            Margin="0,10,0,6">
                                     <StackPanel DockPanel.Dock="Right"
                                                 Orientation="Horizontal">
                                         <Button x:Name="SnapshotCreateButton"
                                                 Content="생성"
                                                 Tag="snapshot.createCurrent"
                                                 MinWidth="52"
                                                 Height="26"
                                                 Margin="0,0,6,0"
                                                 Padding="8,0"
                                                 Click="CommandButton_Click"/>
                                         <Button x:Name="SnapshotRestoreButton"
                                                 Content="복원"
                                                 Tag="snapshot.restoreSelected"
                                                 MinWidth="52"
                                                 Height="26"
                                                 Margin="0,0,6,0"
                                                 Padding="8,0"
                                                 Click="CommandButton_Click"/>
                                         <Button x:Name="SnapshotDeleteButton"
                                                 Content="삭제"
                                                 Tag="snapshot.deleteSelected"
                                                 MinWidth="52"
                                                 Height="26"
                                                 Padding="8,0"
                                                 Click="CommandButton_Click"/>
                                     </StackPanel>
                                     <TextBlock Text="스냅샷"
                                                FontWeight="SemiBold"
                                                VerticalAlignment="Center"/>
                                 </DockPanel>
                                  <ListBox x:Name="SnapshotList"
                                           Grid.Row="12"
                                           Grid.ColumnSpan="2"
                                           BorderBrush="#D1D5DB"
                                           DisplayMemberPath="Display"/>
                                  <DockPanel Grid.Row="13"
                                             Grid.ColumnSpan="2"
                                             Margin="0,10,0,6">
                                      <StackPanel DockPanel.Dock="Right"
                                                  Orientation="Horizontal">
                                          <Button x:Name="SceneEntityLinkAddButton"
                                                  Content="연결"
                                                  Tag="sceneEntity.link.add"
                                                  MinWidth="52"
                                                  Height="26"
                                                  Margin="0,0,6,0"
                                                  Padding="8,0"
                                                  Click="CommandButton_Click"/>
                                          <Button x:Name="SceneEntityLinkDeleteButton"
                                                  Content="해제"
                                                  Tag="sceneEntity.link.delete"
                                                  MinWidth="52"
                                                  Height="26"
                                                  Padding="8,0"
                                                  Click="CommandButton_Click"/>
                                      </StackPanel>
                                      <TextBlock Text="장면 연결"
                                                 FontWeight="SemiBold"
                                                 VerticalAlignment="Center"/>
                                  </DockPanel>
                                  <Grid Grid.Row="14"
                                        Grid.ColumnSpan="2">
                                      <Grid.RowDefinitions>
                                          <RowDefinition Height="Auto"/>
                                          <RowDefinition Height="Auto"/>
                                          <RowDefinition Height="*"/>
                                      </Grid.RowDefinitions>
                                      <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="*"/>
                                          <ColumnDefinition Width="74"/>
                                      </Grid.ColumnDefinitions>
                                      <ComboBox x:Name="SceneEntityLinkEntityBox"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Height="26"
                                                Margin="0,0,6,6"
                                                DisplayMemberPath="Display"/>
                                      <TextBox x:Name="SceneEntityLinkRoleBox"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               Height="26"
                                               Text="등장"
                                               VerticalContentAlignment="Center"
                                               Margin="0,0,0,6"/>
                                      <TextBox x:Name="SceneEntityLinkNotesBox"
                                               Grid.Row="1"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="2"
                                               Height="28"
                                               VerticalContentAlignment="Center"
                                               Margin="0,0,0,6"/>
                                      <ListBox x:Name="SceneEntityLinkList"
                                               Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               BorderBrush="#D1D5DB"
                                               DisplayMemberPath="Display"
                                               SelectionChanged="SceneEntityLinkList_SelectionChanged"/>
                                  </Grid>
                              </Grid>
                              </ScrollViewer>
                        </DockPanel>
                    </Border>
                    <ListBox x:Name="SearchResultsList"
                             BorderThickness="0"
                             DisplayMemberPath="Display"
                             SelectionChanged="SearchResultsList_SelectionChanged"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
