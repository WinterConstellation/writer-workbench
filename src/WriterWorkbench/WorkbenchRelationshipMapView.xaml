<UserControl x:Class="WriterWorkbench.WorkbenchRelationshipMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Malgun Gothic"
             Background="White">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top"
                       Text="인물"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <ListBox x:Name="DetachedRelationshipEntityList"
                     DockPanel.Dock="Top"
                     Height="210"
                     DisplayMemberPath="Display"/>
            <TextBlock DockPanel.Dock="Top"
                       Text="관계"
                       FontWeight="SemiBold"
                       Margin="0,12,0,6"/>
            <ListBox x:Name="DetachedRelationshipList"
                     DisplayMemberPath="Display"/>
        </DockPanel>

        <Border Grid.Column="1"
                Background="#F8FAFC"
                BorderBrush="#CBD5E1"
                BorderThickness="1">
            <Canvas x:Name="DetachedRelationshipMapCanvas"
                    ClipToBounds="True"
                    Background="#F8FAFC"/>
        </Border>

        <Border Grid.Column="2"
                Margin="12,0,0,0"
                Padding="12"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="관계도"
                           FontWeight="SemiBold"
                           FontSize="15"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="DetachedRelationshipMapSummaryText"
                           TextWrapping="Wrap"
                           Foreground="#374151"/>
                <TextBlock Text="노드는 드래그해 위치를 저장할 수 있습니다."
                           Margin="0,14,0,0"
                           TextWrapping="Wrap"
                           Foreground="#6B7280"
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
