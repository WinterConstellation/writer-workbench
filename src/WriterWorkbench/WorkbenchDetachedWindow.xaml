<Window x:Class="WriterWorkbench.WorkbenchDetachedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="분리 작업대"
        Width="760"
        Height="520"
        MinWidth="520"
        MinHeight="360"
        FontFamily="Malgun Gothic"
        Background="White">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Height="52"
                Background="#F5F6F8"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="DetachedEditorSurfaceButton"
                            Content="작품 수정"
                            Tag="editor"
                            MinWidth="92"
                            Height="32"
                            Margin="10,0,0,0"
                            Padding="10,0"
                            Click="SurfaceButton_Click"/>
                    <Button x:Name="DetachedMainSurfaceButton"
                            Content="메인"
                            Tag="main"
                            MinWidth="78"
                            Height="32"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="SurfaceButton_Click"/>
                    <Button x:Name="DetachedPreviewSurfaceButton"
                            Content="미리보기"
                            Tag="preview"
                            MinWidth="88"
                            Height="32"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="SurfaceButton_Click"/>
                    <Button x:Name="DetachedRelationshipMapSurfaceButton"
                            Content="관계도"
                            Tag="relationship-map"
                            MinWidth="82"
                            Height="32"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="SurfaceButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="DetachedWorkbenchStatusText"
                           VerticalAlignment="Center"
                           Margin="16,0,14,0"
                           Foreground="#4B5563"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <Grid>
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="460"
                        Margin="24">
                <TextBlock x:Name="DetachedAssignedSurfaceText"
                           Text="작업대를 선택하세요"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextAlignment="Center"/>
                <TextBlock x:Name="DetachedAssignedSurfaceHintText"
                           Margin="0,12,0,0"
                           Text="이 분리창은 아직 어떤 화면도 차지하지 않았습니다."
                           Foreground="#4B5563"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
