<Window x:Class="WriterWorkbench.SceneRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="장면 이름 변경"
        Width="420"
        Height="170"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Malgun Gothic">
    <DockPanel Margin="14">
        <TextBlock x:Name="SceneIdText"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,8"
                   FontSize="12"
                   Foreground="#4B5563"/>
        <TextBox x:Name="SceneTitleBox"
                 Height="30"
                 VerticalContentAlignment="Center"/>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="확인"
                    Width="82"
                    Height="28"
                    Margin="8,0,0,0"
                    Click="OkButton_Click"/>
            <Button Content="취소"
                    Width="82"
                    Height="28"
                    Margin="8,0,0,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
