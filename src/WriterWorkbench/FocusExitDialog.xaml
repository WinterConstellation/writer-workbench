<Window x:Class="WriterWorkbench.FocusExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="집중모드 해제"
        Width="420"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Malgun Gothic">
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top"
                   Text="조기 해제하려면 확인 문구를 20자 이상 입력하세요."
                   Margin="0,0,0,8"/>
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="확인"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    Click="OkButton_Click"/>
            <Button Content="취소"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
        <TextBox x:Name="ConfirmationBox" Height="28"/>
    </DockPanel>
</Window>
