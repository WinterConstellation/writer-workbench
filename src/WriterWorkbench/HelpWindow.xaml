<Window x:Class="WriterWorkbench.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="도움말"
        Width="920"
        Height="620"
        MinWidth="720"
        MinHeight="460"
        FontFamily="Malgun Gothic"
        Background="#FFFFFF">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Height="58"
                Background="#F5F6F8"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center"
                        Margin="16,0">
                <TextBlock Text="도움말"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="작업대 항목별 역할"
                           Margin="0,3,0,0"
                           FontSize="12"
                           Foreground="#4B5563"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="HelpTopicGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  FontSize="13"
                  RowHeight="42"
                  BorderThickness="0"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="구역"
                                    Binding="{Binding Section}"
                                    Width="110"/>
                <DataGridTextColumn Header="항목"
                                    Binding="{Binding Item}"
                                    Width="140"/>
                <DataGridTextColumn Header="역할"
                                    Binding="{Binding Role}"
                                    Width="2*"/>
                <DataGridTextColumn Header="사용"
                                    Binding="{Binding Usage}"
                                    Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
