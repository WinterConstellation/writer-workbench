<Window x:Class="WriterWorkbench.DetachedDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="분리 창"
        Width="920"
        Height="720"
        MinWidth="640"
        MinHeight="480"
        Topmost="True"
        FontFamily="Malgun Gothic"
        Background="White">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Height="44"
                Background="#F5F6F8"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="저장"
                            MinWidth="88"
                            Height="30"
                            Margin="8,0,0,0"
                            Padding="10,0"
                            Click="SaveButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="DetachedStatusText"
                           VerticalAlignment="Center"
                           Margin="16,0,12,0"
                           Foreground="#4B5563"
                           FontSize="12"
                           Text="분리된 문서"/>
            </DockPanel>
        </Border>

        <TextBlock x:Name="DetachedMetricsText"
                   DockPanel.Dock="Bottom"
                   Height="28"
                   Padding="12,5,12,4"
                   Background="#F3F4F6"
                   Foreground="#374151"
                   FontSize="12"/>

        <DockPanel>
            <TextBox x:Name="DetachedTitleBox"
                     DockPanel.Dock="Top"
                     BorderThickness="0,0,0,1"
                     BorderBrush="#E5E7EB"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Padding="14,10"
                     TextChanged="DetachedTextChanged"/>
            <TextBox x:Name="DetachedEditorBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     UndoLimit="0"
                     TextWrapping="NoWrap"
                     SpellCheck.IsEnabled="False"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     FontSize="18"
                     Padding="28"
                     TextChanged="DetachedTextChanged"/>
        </DockPanel>
    </DockPanel>
</Window>
