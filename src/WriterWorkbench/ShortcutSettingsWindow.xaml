<Window x:Class="WriterWorkbench.ShortcutSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키"
        Width="760"
        Height="620"
        MinWidth="620"
        MinHeight="420"
        FontFamily="Malgun Gothic"
        Background="White">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Height="44"
                Background="#F5F6F8"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Content="취소"
                            MinWidth="84"
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="10,0"
                            Click="CancelButton_Click"/>
                    <Button Content="저장"
                            MinWidth="84"
                            Height="30"
                            Padding="10,0"
                            Click="SaveButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="ShortcutStatusText"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           Foreground="#374151"
                           FontSize="12"
                           Text="단축키를 직접 입력하세요. 예: Ctrl+Alt+1"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="ShortcutGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  Margin="0"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="명령"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True"
                                    Width="150"/>
                <DataGridTextColumn Header="분류"
                                    Binding="{Binding Category}"
                                    IsReadOnly="True"
                                    Width="110"/>
                <DataGridTextColumn Header="범위"
                                    Binding="{Binding Scope}"
                                    IsReadOnly="True"
                                    Width="120"/>
                <DataGridTextColumn Header="단축키"
                                    Binding="{Binding Gesture, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="{x:Type TextBox}">
                            <Setter Property="IsReadOnly" Value="True"/>
                            <EventSetter Event="PreviewKeyDown" Handler="ShortcutGestureBox_PreviewKeyDown"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="명령 ID"
                                    Binding="{Binding CommandId}"
                                    IsReadOnly="True"
                                    Width="220"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
