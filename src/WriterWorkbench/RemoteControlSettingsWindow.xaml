<Window x:Class="WriterWorkbench.RemoteControlSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="리모콘 편집"
        Width="820"
        Height="620"
        MinWidth="680"
        MinHeight="460"
        FontFamily="Malgun Gothic"
        Background="White">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Height="48"
                Background="#F5F6F8"
                BorderBrush="#D1D5DB"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Content="취소"
                            MinWidth="84"
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="10,0"
                            Click="CancelButton_Click"/>
                    <Button Content="저장"
                            MinWidth="84"
                            Height="30"
                            Padding="10,0"
                            Click="SaveButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="RemoteControlStatusText"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           Foreground="#374151"
                           FontSize="12"
                           Text="리모콘에 둘 명령을 체크하고 표시명과 순서를 조정하세요."/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="RemoteControlGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  Margin="0"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="리모콘"
                                        Binding="{Binding ShowInRemote, UpdateSourceTrigger=PropertyChanged}"
                                        Width="72"/>
                <DataGridTextColumn Header="순서"
                                    Binding="{Binding Order, UpdateSourceTrigger=PropertyChanged}"
                                    Width="72"/>
                <DataGridTextColumn Header="표시명"
                                    Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150"/>
                <DataGridTextColumn Header="명령"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True"
                                    Width="160"/>
                <DataGridTextColumn Header="분류"
                                    Binding="{Binding Category}"
                                    IsReadOnly="True"
                                    Width="120"/>
                <DataGridTextColumn Header="명령 ID"
                                    Binding="{Binding CommandId}"
                                    IsReadOnly="True"
                                    Width="240"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
