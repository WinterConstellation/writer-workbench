<Window x:Class="WriterWorkbench.RemoteControlPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="리모콘"
        Width="124"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        FontFamily="Malgun Gothic"
        Background="#F8FAFC">
    <Border BorderBrush="#CBD5E1"
            BorderThickness="1"
            Background="#F8FAFC">
        <StackPanel Margin="6">
            <DockPanel Margin="0,0,0,6">
                <Button x:Name="RemoteEditButton"
                        DockPanel.Dock="Right"
                        Content="편집"
                        Tag="remote.openSettings"
                        Height="24"
                        MinWidth="44"
                        Padding="7,0"
                        FontSize="11"
                        Click="RemoteButton_Click"/>
                <TextBlock Text="리모콘"
                           VerticalAlignment="Center"
                           Foreground="#111827"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </DockPanel>
            <StackPanel x:Name="RemoteButtonPanel"
                        Orientation="Vertical"/>
        </StackPanel>
    </Border>
</Window>
