<Window x:Class="WriterWorkbench.RemoteControlLayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="리모콘"
        Width="260"
        Height="450"
        MinWidth="54"
        MinHeight="92"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        FontFamily="Malgun Gothic"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="RemoteInkBrush" Color="#1F252B"/>
        <SolidColorBrush x:Key="RemoteSurfaceBrush" Color="#FFFAF0"/>
        <SolidColorBrush x:Key="RemoteSurfaceSoftBrush" Color="#F3EFE6"/>
        <SolidColorBrush x:Key="RemoteSurfaceStrongBrush" Color="#E3D8C8"/>
        <SolidColorBrush x:Key="RemoteLineBrush" Color="#9F927F"/>
        <SolidColorBrush x:Key="RemoteAccentBrush" Color="#245C73"/>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource RemoteSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RemoteLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource RemoteInkBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonFrame"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource RemoteSurfaceSoftBrush}"/>
                                <Setter TargetName="ButtonFrame" Property="BorderBrush" Value="{StaticResource RemoteAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFrame" Property="Background" Value="{StaticResource RemoteSurfaceStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border x:Name="RemoteLayerFrame"
            BorderBrush="{StaticResource RemoteLineBrush}"
            BorderThickness="1"
            Background="{StaticResource RemoteSurfaceBrush}"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="6"
                              Opacity="0.18"
                              Color="#1F252B"/>
        </Border.Effect>
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border x:Name="RemoteLayerDragHandle"
                    Grid.Row="0"
                    Height="26"
                    Margin="0,0,0,6"
                    Padding="6,0"
                    BorderBrush="{StaticResource RemoteLineBrush}"
                    BorderThickness="1"
                    Background="{StaticResource RemoteSurfaceStrongBrush}"
                    CornerRadius="5"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="RemoteLayerDragHandle_MouseLeftButtonDown">
                <DockPanel>
                    <Button x:Name="RemoteLayerEditButton"
                            DockPanel.Dock="Right"
                            Content="편집"
                            Tag="remote.openSettings"
                            Height="20"
                            MinWidth="40"
                            Padding="5,0"
                            FontSize="10"
                            Click="RemoteButton_Click"/>
                    <Button x:Name="RemoteLayerDisplayModeButton"
                            DockPanel.Dock="Right"
                            Content="아이콘만"
                            Height="20"
                            MinWidth="54"
                            Margin="0,0,4,0"
                            Padding="5,0"
                            FontSize="10"
                            Click="RemoteLayerDisplayModeButton_Click"/>
                    <Viewbox x:Name="RemoteLayerMoveIcon"
                             Width="24"
                             Height="18"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource RemoteAccentBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M12,3 L12,21 M3,12 L21,12"/>
                            <Path Fill="{StaticResource RemoteAccentBrush}"
                                  Data="M12,0 L8.5,4 H15.5 Z M12,24 L8.5,20 H15.5 Z M0,12 L4,8.5 V15.5 Z M24,12 L20,8.5 V15.5 Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="리모콘"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource RemoteInkBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"/>
                </DockPanel>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="RemoteLayerButtonPanel"
                            Orientation="Vertical"/>
            </ScrollViewer>
            <ResizeGrip x:Name="RemoteLayerResizeGrip"
                        Grid.Row="2"
                        Width="16"
                        Height="16"
                        Margin="0,2,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</Window>
