<Window x:Class="WriterWorkbench.RemoteControlLayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="리모콘"
        Width="124"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        FontFamily="Malgun Gothic"
        Background="Transparent"
        AllowsTransparency="True">
    <Border BorderBrush="#334155"
            BorderThickness="1"
            Background="#F8FAFC"
            CornerRadius="8">
        <StackPanel Margin="6">
            <Border x:Name="RemoteLayerDragHandle"
                    Height="26"
                    Margin="0,0,0,6"
                    Padding="6,0"
                    Background="#E2E8F0"
                    CornerRadius="5"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="RemoteLayerDragHandle_MouseLeftButtonDown">
                <DockPanel>
                    <Button x:Name="RemoteLayerEditButton"
                            DockPanel.Dock="Right"
                            Content="편집"
                            Tag="remote.openSettings"
                            Height="20"
                            MinWidth="40"
                            Padding="5,0"
                            FontSize="10"
                            Click="RemoteButton_Click"/>
                    <TextBlock Text="리모콘"
                               VerticalAlignment="Center"
                               Foreground="#111827"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </DockPanel>
            </Border>
            <StackPanel x:Name="RemoteLayerButtonPanel"
                        Orientation="Vertical"/>
        </StackPanel>
    </Border>
</Window>
