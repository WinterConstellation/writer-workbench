<Window x:Class="WriterWorkbench.RemoteControlLayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="리모콘"
        Width="260"
        Height="450"
        MinWidth="54"
        MinHeight="92"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        FontFamily="Malgun Gothic"
        Background="Transparent"
        AllowsTransparency="True">
    <Border BorderBrush="#334155"
            BorderThickness="1"
            Background="#F8FAFC"
            CornerRadius="8">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border x:Name="RemoteLayerDragHandle"
                    Grid.Row="0"
                    Height="26"
                    Margin="0,0,0,6"
                    Padding="6,0"
                    Background="#E2E8F0"
                    CornerRadius="5"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="RemoteLayerDragHandle_MouseLeftButtonDown">
                <DockPanel>
                    <Button x:Name="RemoteLayerEditButton"
                            DockPanel.Dock="Right"
                            Content="편집"
                            Tag="remote.openSettings"
                            Height="20"
                            MinWidth="40"
                            Padding="5,0"
                            FontSize="10"
                            Click="RemoteButton_Click"/>
                    <Button x:Name="RemoteLayerDisplayModeButton"
                            DockPanel.Dock="Right"
                            Content="아이콘만"
                            Height="20"
                            MinWidth="54"
                            Margin="0,0,4,0"
                            Padding="5,0"
                            FontSize="10"
                            Click="RemoteLayerDisplayModeButton_Click"/>
                    <TextBlock x:Name="RemoteLayerMoveGlyph"
                               Text="↕↔"
                               Width="30"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="#475569"
                               FontSize="14"
                               FontWeight="Bold"/>
                    <TextBlock Text="리모콘"
                               VerticalAlignment="Center"
                               Foreground="#111827"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </DockPanel>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="RemoteLayerButtonPanel"
                            Orientation="Vertical"/>
            </ScrollViewer>
            <ResizeGrip x:Name="RemoteLayerResizeGrip"
                        Grid.Row="2"
                        Width="16"
                        Height="16"
                        Margin="0,2,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</Window>
